# Anything that could carry secrets, credentials, or PII.
# Belt-and-suspenders alongside GitHub secret-scanning push protection.

# --- environment / dotenv -----------------------------------------------------
.env
.env.*
!.env.example
.envrc
.envrc.local
*.env

# --- credentials, keys, tokens ------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*.keystore
*.gpg
*.asc
*_token
*.token
*credentials*
.netrc
.pypirc
.npmrc
.gem/credentials
.docker/config.json
.aws/
.gcp/
.azure/
gcloud-credentials.json
service-account*.json
id_rsa*
id_ed25519*
id_dsa*
id_ecdsa*
*.ppk

# --- HTTP archives / API client state (often contain Authorization headers) --
*.har
.insomnia/
.postman/

# --- local config overrides ---------------------------------------------------
*.local
*.local.*
settings.local.json
config.local.*

# --- editor / IDE state -------------------------------------------------------
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.history/
.ionide/

# --- agent / AI tool state ----------------------------------------------------
.claude/
.cursor/
.aider*
.continue/

# --- OS detritus --------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# --- logs (frequently capture tokens, request bodies, stack traces with PII) -
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python -------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# --- Node (not used today, but pre-empts accidental commits if added) --------
node_modules/
.pnpm-store/
.yarn/
.npm/

# --- backups / scratch / merge leftovers --------------------------------------
*.bak
*.orig
*.rej
*.tmp
*.old

# --- local sample media used while developing the converter ------------------
# Avoid accidentally committing test videos / exports that might contain PII.
*.mp4
*.mov
*.mkv
*.webm
*.avi
*.gif
!docs/**/*.gif
